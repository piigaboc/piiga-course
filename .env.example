# ---------------------------------------------------------------------------
# piigacourse - local environment template
# Copy to backend/.env (backend vars) and frontend/.env (VITE_ vars), or to a
# single root .env if your tooling loads from the project root.
#   PowerShell:  Copy-Item .env.example backend\.env
# ---------------------------------------------------------------------------

# --- Backend (FastAPI) -----------------------------------------------------

# Async SQLAlchemy DSN. Matches the Postgres credentials in docker-compose.yml.
# For a hosted DB (e.g. Neon / Render), paste the provider's FULL URL AS-IS,
# e.g. postgresql://user:pass@ep-xxx.aws.neon.tech/neondb?sslmode=require&channel_binding=require
# The app normalizes scheme + SSL automatically (rewrites to postgresql+asyncpg,
# strips sslmode/channel_binding/..., and enables SSL for non-localhost hosts).
DATABASE_URL=postgresql+asyncpg://piiga:piiga@localhost:5432/piigacourse

# JWT signing secret. DO NOT use this placeholder in any real use.
# Generate a strong value:  openssl rand -hex 32
SECRET_KEY=replace-me-with-openssl-rand-hex-32

# Access token lifetime (minutes).
ACCESS_TOKEN_EXPIRE_MIN=60

# Window (minutes) a pending-MFA login challenge stays valid.
MFA_PENDING_EXPIRE_MIN=5

# Allowed browser origins for CORS (comma-separated if more than one).
CORS_ORIGINS=http://localhost:5173

# Single bootstrap user, created on first run by the bootstrap step.
BOOTSTRAP_EMAIL=you@example.com
BOOTSTRAP_PASSWORD=change-me

# --- Frontend (Vite) -------------------------------------------------------

# Base path the SPA uses for API calls (proxied to the backend in dev).
VITE_API_BASE_URL=/api
