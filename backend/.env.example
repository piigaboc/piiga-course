# PiigaCourse backend environment (single-user, local Postgres).
# Copy to .env and adjust. Never commit the real .env.

# --- Database (SQLAlchemy async DSN) ---
# Local default below. For a hosted DB (e.g. Neon) you can paste the provider's
# FULL connection string AS-IS, including its query params, for example:
#   DATABASE_URL=postgresql://user:pass@ep-xxx.aws.neon.tech/neondb?sslmode=require&channel_binding=require
# The app normalizes it automatically: it rewrites the scheme to
# postgresql+asyncpg, strips libpq-only params (sslmode/channel_binding/...),
# and enables SSL for any non-localhost host. No manual editing required.
DATABASE_URL=postgresql+asyncpg://piiga:piiga@localhost:5432/piigacourse

# --- Security / JWT ---
# REQUIRED. Must be a random value of at least 32 characters. The app refuses
# to start on an empty / placeholder / too-short value. Generate one with:
#   openssl rand -hex 32
# (or: python -c "import secrets; print(secrets.token_urlsafe(48))")
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MIN=60
MFA_PENDING_EXPIRE_MIN=5

# --- CORS (comma-separated origins) ---
CORS_ORIGINS=http://localhost:5173

# --- Single-user bootstrap account ---
# BOTH must be set (and the password must NOT be a placeholder like "change-me")
# for the single account to be seeded on first run. If either is empty, or the
# password is a known placeholder, bootstrap logs a warning and SKIPS seeding —
# no guessable account is ever created. Use a strong, unique password.
BOOTSTRAP_EMAIL=
BOOTSTRAP_PASSWORD=
